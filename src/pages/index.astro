---
import type { ClientData, Schedule } from '../types/client';
import MainLayout from '../layouts/MainLayout.astro';
import HeaderSection from '../sections/HeaderSection.astro';
import HeroSection from '../sections/HeroSection.astro';
import AboutSection from '../sections/AboutSection.astro';
import MenuSection from '../sections/MenuSection.astro';
import GallerySection from '../sections/GallerySection.astro';
import ReviewsSection from '../sections/ReviewsSection.astro';
import ContactSection from '../sections/ContactSection.astro';
import FooterSection from '../sections/FooterSection.astro';
import rawData from '../content/clients/demo-restaurant.json';

const data = rawData as const satisfies ClientData;

// Build JSON-LD structured data — all values from client data
const dayMap: Record<keyof Schedule, string> = {
  monday: 'Monday',
  tuesday: 'Tuesday',
  wednesday: 'Wednesday',
  thursday: 'Thursday',
  friday: 'Friday',
  saturday: 'Saturday',
  sunday: 'Sunday',
};

const openingHours = (Object.entries(data.schedule) as [keyof Schedule, string][])
  .filter(([_, hours]) => hours !== 'Cerrado')
  .flatMap(([day, hours]) =>
    hours.split(',').map((range) => {
      const trimmed = range.trim();
      const [opens, closes] = trimmed.split(' - ');
      return {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: dayMap[day],
        opens: opens?.trim(),
        closes: closes?.trim(),
      };
    })
  );

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: data.name,
  description: data.seo.description,
  telephone: data.contact.phone,
  email: data.contact.email,
  image: data.seo.image,
  address: {
    '@type': 'PostalAddress',
    streetAddress: data.contact.address,
  },
  openingHoursSpecification: openingHours,
};
---

<MainLayout
  title={data.seo.title}
  description={data.seo.description}
  ogImage={data.seo.image}
>
  <HeaderSection name={data.name} sections={data.sections} />
  <main class="pt-16">
    {data.sections.hero && (
      <HeroSection
        name={data.name}
        tagline={data.tagline}
        description={data.description}
        cta={data.cta}
        heroImage={data.images.hero}
      />
    )}
    {data.sections.about && (
      <AboutSection about={data.about} image={data.images.interior} />
    )}
    {data.sections.menu && (
      <MenuSection menu={data.menu} cta={data.cta} featuredDishes={data.featuredDishes} />
    )}
    {data.sections.gallery && (
      <GallerySection gallery={data.images.gallery} />
    )}
    {data.sections.reviews && (
      <ReviewsSection reviews={data.reviews} />
    )}
    {data.sections.contact && (
      <ContactSection contact={data.contact} schedule={data.schedule} />
    )}
  </main>
  <FooterSection name={data.name} social={data.social} footer={data.footer} contact={data.contact} />

  <button
    id="scroll-to-top"
    class="fixed bottom-6 right-6 z-50 flex h-10 w-10 items-center justify-center rounded-full border border-stone-700 bg-stone-900/90 text-amber-400 shadow-lg backdrop-blur-sm transition-all duration-500 hover:bg-amber-600 hover:text-white opacity-0 translate-y-4 pointer-events-none"
    aria-label="Volver arriba"
    type="button"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
    </svg>
  </button>

  <script>
    const btn = document.getElementById('scroll-to-top');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 600) {
        btn?.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
        btn?.classList.add('opacity-100', 'translate-y-0');
      } else {
        btn?.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
        btn?.classList.remove('opacity-100', 'translate-y-0');
      }
    });
    btn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  </script>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</MainLayout>
