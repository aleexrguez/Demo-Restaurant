---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="text-center">
  <h2 class="text-3xl font-bold text-white sm:text-4xl">{title}</h2>
  <div class="mx-auto mt-4 h-1 w-16 bg-amber-500"></div>
  {subtitle && <p class="mt-3 text-stone-400">{subtitle}</p>}
</div>
