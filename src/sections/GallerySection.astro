---
import type { GalleryImage } from '../types/client';
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
  gallery: GalleryImage[];
}

const { gallery } = Astro.props;
---

<section id="galeria" class="scroll-mt-20 bg-stone-950 py-20 px-6">
  <div class="mx-auto max-w-5xl">
    <SectionHeading title="Galería" />

    <div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3 md:grid-rows-2">
      {gallery.map((img, i) => (
        <div class={`group overflow-hidden rounded-xl ${i === 0 ? 'col-span-2 row-span-2' : ''}`}>
          <img
            src={img.src}
            alt={img.alt}
            class={`w-full object-cover transition-transform duration-300 group-hover:scale-105 ${i === 0 ? 'h-full' : 'aspect-square'}`}
          />
        </div>
      ))}
    </div>
  </div>
</section>
