---
import type { Sections } from '../types/client';

interface Props {
  name: string;
  sections: Sections;
}

const { name, sections } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-stone-800 bg-stone-950/90 backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a href="#inicio" class="text-lg font-bold text-amber-400 transition-colors duration-300 hover:text-amber-300">{name}</a>

    <nav class="hidden gap-6 md:flex">
      <a href="#inicio" class="text-stone-300 transition-colors hover:text-amber-400">Inicio</a>
      {sections.about && (
        <a href="#sobre-nosotros" class="text-stone-300 transition-colors hover:text-amber-400">Nosotros</a>
      )}
      {sections.menu && (
        <a href="#carta" class="text-stone-300 transition-colors hover:text-amber-400">Carta</a>
      )}
      {sections.gallery && (
        <a href="#galeria" class="text-stone-300 transition-colors hover:text-amber-400">Galería</a>
      )}
      {sections.reviews && (
        <a href="#opiniones" class="text-stone-300 transition-colors hover:text-amber-400">Opiniones</a>
      )}
      {sections.contact && (
        <a href="#contacto" class="text-stone-300 transition-colors hover:text-amber-400">Contacto</a>
      )}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="text-stone-300 md:hidden"
      aria-label="Abrir menú"
      type="button"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-b border-stone-800 bg-stone-950 md:hidden">
    <nav class="flex flex-col">
      <a href="#inicio" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Inicio</a>
      {sections.about && (
        <a href="#sobre-nosotros" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Nosotros</a>
      )}
      {sections.menu && (
        <a href="#carta" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Carta</a>
      )}
      {sections.gallery && (
        <a href="#galeria" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Galería</a>
      )}
      {sections.reviews && (
        <a href="#opiniones" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Opiniones</a>
      )}
      {sections.contact && (
        <a href="#contacto" class="px-6 py-3 text-stone-300 transition-colors hover:text-amber-400">Contacto</a>
      )}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
