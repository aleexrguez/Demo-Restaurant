---
import type { About } from '../types/client';
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
  about: About;
}

const { about } = Astro.props;
---

<section id="sobre-nosotros" class="bg-stone-900 py-20 px-6">
  <div class="mx-auto max-w-3xl text-center">
    <SectionHeading title={about.title} />
    <p class="mt-8 text-lg leading-relaxed text-stone-300">{about.text}</p>
  </div>
</section>
