---
import type { About } from '../types/client';

interface Props {
  about: About;
  image: string;
}

const { about, image } = Astro.props;
---

<section id="sobre-nosotros" class="scroll-mt-20 bg-stone-900 py-20 px-6">
  <div class="mx-auto max-w-5xl">
    <div class="grid grid-cols-1 items-center gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold text-white sm:text-4xl">{about.title}</h2>
        <div class="mt-4 h-1 w-16 bg-amber-500"></div>
        <p class="mt-8 text-lg leading-relaxed text-stone-300">
          {about.text}
        </p>
      </div>
      <div>
        <img
          src={image}
          alt={about.title}
          class="w-full rounded-xl object-cover shadow-lg shadow-black/30"
        />
      </div>
    </div>
  </div>
</section>
