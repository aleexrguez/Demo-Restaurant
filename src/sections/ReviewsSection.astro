---
import type { Review } from '../types/client';
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
  reviews: Review[];
}

const { reviews } = Astro.props;
---

<section id="opiniones" class="scroll-mt-20 bg-stone-900 py-20 px-6">
  <div class="mx-auto max-w-5xl">
    <SectionHeading title="Opiniones" />

    <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
      {reviews.map((review) => (
        <div class="rounded-xl border border-stone-700 bg-stone-800/50 p-6">
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill={i < review.rating ? 'currentColor' : 'none'}
                stroke="currentColor"
                stroke-width="1.5"
                class={i < review.rating ? 'text-amber-400' : 'text-stone-600'}
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
                />
              </svg>
            ))}
          </div>
          <p class="mt-4 leading-relaxed text-stone-300">"{review.text}"</p>
          <p class="mt-4 text-sm font-semibold text-amber-400">— {review.name}</p>
        </div>
      ))}
    </div>
  </div>
</section>
